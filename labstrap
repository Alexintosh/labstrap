#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source_path="${BASH_SOURCE[0]}"
  while [[ -h "$source_path" ]]; do
    local source_dir
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    source_path="$(readlink "$source_path")"
    [[ "$source_path" != /* ]] && source_path="$source_dir/$source_path"
  done
  cd -P "$(dirname "$source_path")" && pwd
}

ROOT_DIR="$(resolve_script_path)"
ANSIBLE_DIR="$ROOT_DIR/ansible"
PRECHECK_SCRIPT="$ROOT_DIR/checks/preflight.sh"
DEFAULT_CONFIG="$ROOT_DIR/defaults/config.yml"
CONFIG_PATH="${LABSTRAP_CONFIG:-$DEFAULT_CONFIG}"
LABSTRAP_LOG_FILE="${LABSTRAP_LOG_FILE:-}"
LOG_COMMAND=""

json_escape() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

log_event() {
  local level="$1"
  local event="$2"
  local message="$3"
  shift 3 || true

  local ts
  local json
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  json="{\"timestamp\":\"$ts\",\"level\":\"$(json_escape "$level")\",\"event\":\"$(json_escape "$event")\",\"command\":\"$(json_escape "$LOG_COMMAND")\",\"message\":\"$(json_escape "$message")\""

  while [[ "$#" -ge 2 ]]; do
    local key="$1"
    local value="$2"
    shift 2
    json="$json,\"$(json_escape "$key")\":\"$(json_escape "$value")\""
  done
  json="$json}"

  printf '%s\n' "$json"
  if [[ -n "$LABSTRAP_LOG_FILE" ]]; then
    printf '%s\n' "$json" >> "$LABSTRAP_LOG_FILE" || true
  fi
}

truncate_text() {
  local text="${1:-}"
  local limit="${2:-300}"
  if [[ ${#text} -le $limit ]]; then
    printf '%s' "$text"
    return
  fi
  printf '%s...' "${text:0:limit}"
}

suggest_failure_hint() {
  local phase="$1"
  local task="$2"
  local detail="$3"
  local user_name
  user_name="$(config_value user 2>/dev/null || true)"
  [[ -n "$user_name" ]] || user_name="lab"

  if [[ "$phase" == "harden" && "$task" == *"Ensure at least one SSH key exists"* ]]; then
    echo "No SSH key found for user '$user_name'. Run: sudo labstrap allow-key /path/to/key.pub ; then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$detail" == *"Tailscale is not active"* || "$task" == *"Verify Tailscale is connected"* ]]; then
    echo "Complete Tailscale authentication, then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$detail" == *"tailscale up timed out"* || "$task" == *"Bring up Tailscale"* ]]; then
    echo "Run: sudo tailscale up --ssh=false ; complete auth in browser ; then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$detail" == *"Homebrew is required"* ]]; then
    echo "Run the Homebrew component first: sudo labstrap extras homebrew"
    return
  fi

  if [[ "$detail" == *"/home/linuxbrew/.linuxbrew"* || "$detail" == *"Homebrew installation failed"* ]]; then
    echo "Homebrew issue. Fix ownership and retry: sudo mkdir -p /home/linuxbrew/.linuxbrew && sudo chown -R $(config_value user):$(config_value user) /home/linuxbrew ; then rerun: sudo labstrap extras homebrew (or interactive mode: sudo LABSTRAP_HOMEBREW_INTERACTIVE=1 labstrap extras homebrew)"
    return
  fi

  if [[ "$detail" == *"Node runtime is required"* ]]; then
    echo "Run the Node component first: sudo labstrap extras node"
    return
  fi

  if [[ "$phase" == "extras" && "$task" == *"Fail when one or more extras components failed"* ]]; then
    echo "Run: sudo labstrap doctor ; then rerun only failed components (example: sudo labstrap extras tsx)"
    return
  fi

  if [[ "$detail" == *".npmrc"* && "$detail" == *"incompatible with nvm"* ]]; then
    echo "Your ~/.npmrc has prefix/globalconfig incompatible with nvm. Remove those lines and rerun: sudo labstrap extras node && sudo labstrap extras codex"
    return
  fi

  if [[ "$detail" == *"Claude Code installation finished without producing"* ]]; then
    echo "Claude Code CLI install failed. Run: sudo labstrap extras node && sudo labstrap extras claudecode"
    return
  fi

  if [[ "$detail" == *"tsx installation finished without producing"* ]]; then
    echo "tsx install failed. Run: sudo labstrap extras node && sudo labstrap extras tsx"
    return
  fi

  if [[ "$detail" == *"Kimi installation finished without producing"* ]]; then
    echo "Kimi install failed. Verify internet access, then rerun: sudo labstrap extras kimi"
    return
  fi

  if [[ "$detail" == *"Camoufox installation did not create"* ]]; then
    echo "Camoufox install failed. Rerun with: sudo labstrap extras camoufox"
    return
  fi

  if [[ "$detail" == *"Cargo installation finished without producing"* ]]; then
    echo "Cargo install failed. Rerun with: sudo labstrap extras cargo"
    return
  fi

  if [[ "$detail" == *"OpenClaw installation finished without producing"* ]]; then
    echo "OpenClaw install failed. Rerun with: sudo labstrap extras openclaw"
    return
  fi

  if [[ "$detail" == *"bun installation finished without producing"* ]]; then
    echo "bun install failed. Rerun with: sudo labstrap extras bun"
    return
  fi

  if [[ "$detail" == *"Whisper installation finished without producing"* ]]; then
    echo "Whisper install failed. Rerun with: sudo labstrap extras whisper"
    return
  fi

  if [[ "$detail" == *"rbw installation finished without producing"* ]]; then
    echo "rbw install failed. Run: sudo labstrap extras homebrew && sudo labstrap extras rbw"
    return
  fi

  if [[ "$task" == *"Install nvm"* && "$detail" == *"Host key verification failed"* ]]; then
    echo "nvm git checkout failed due submodule host-key verification. Run: sudo rm -rf \"$(getent passwd $(config_value user) | cut -d: -f6)/.nvm\" ; then rerun: sudo labstrap extras node"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Ensure SSH is listening on configured port"* ]]; then
    echo "SSH did not come up on the configured port. Check /etc/ssh/sshd_config and run: sudo sshd -t"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Ensure ssh service is active"* ]]; then
    echo "SSH service is not active. Check: sudo systemctl status ssh ; if absent, check: sudo systemctl status sshd"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Validate SSH daemon configuration"* ]]; then
    echo "Invalid sshd config. Run: sudo /usr/sbin/sshd -t -f /etc/ssh/sshd_config ; fix errors ; rerun: sudo labstrap harden"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Fail if SSH daemon configuration is invalid"* ]]; then
    echo "Fix /etc/ssh/sshd_config syntax then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$detail" == *"Missing privilege separation directory"* ]]; then
    echo "Create runtime dir and retry: sudo mkdir -p /run/sshd && sudo chmod 755 /run/sshd ; then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Ensure OpenSSH server is installed"* ]]; then
    echo "OpenSSH server install failed. Run: sudo apt-get update && sudo apt-get install -y openssh-server ; then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Ensure tailscale0 firewall allowance exists"* ]]; then
    echo "UFW policy is missing tailscale0 allowance. Run: sudo ufw status verbose"
    return
  fi

  if [[ "$phase" == "preflight" ]]; then
    echo "Fix the preflight issue and rerun the same command."
    return
  fi

  echo "See log file for details: $LABSTRAP_LOG_FILE"
}

print_preflight_failure_summary() {
  local phase="$1"
  local line
  local msg

  if ! command -v python3 >/dev/null 2>&1; then
    echo "ERROR: Preflight failed for phase '$phase'. See log: $LABSTRAP_LOG_FILE" >&2
    return
  fi

  line="$(python3 - "$LABSTRAP_LOG_FILE" "$phase" <<'PY'
import json
import sys

path = sys.argv[1]
phase = sys.argv[2]
last = None
with open(path, "r", encoding="utf-8") as fp:
    for raw in fp:
        raw = raw.strip()
        if not raw:
            continue
        try:
            event = json.loads(raw)
        except json.JSONDecodeError:
            continue
        if event.get("event") == "preflight.check_failed" and event.get("phase") == phase:
            last = event

if last:
    print(last.get("message", "Preflight check failed"))
PY
)"

  msg="$(truncate_text "$line" 300)"
  if [[ -n "$msg" ]]; then
    echo "ERROR: Preflight failed for phase '$phase': $msg" >&2
    echo "Next: $(suggest_failure_hint "preflight" "" "$msg")" >&2
    echo "Log: $LABSTRAP_LOG_FILE" >&2
    return
  fi

  echo "ERROR: Preflight failed for phase '$phase'. See log: $LABSTRAP_LOG_FILE" >&2
}

print_ansible_failure_summary() {
  local phase="$1"
  local summary
  local task=""
  local status=""
  local detail=""
  local hint=""

  if ! command -v python3 >/dev/null 2>&1; then
    echo "ERROR: Phase '$phase' failed. See log: $LABSTRAP_LOG_FILE" >&2
    return
  fi

  summary="$(python3 - "$LABSTRAP_LOG_FILE" "$phase" <<'PY'
import json
import sys

path = sys.argv[1]
phase = sys.argv[2]
failure = None

with open(path, "r", encoding="utf-8") as fp:
    for raw in fp:
        raw = raw.strip()
        if not raw:
            continue
        try:
            event = json.loads(raw)
        except json.JSONDecodeError:
            continue
        if event.get("event") == "ansible.task" and event.get("phase") == phase and event.get("status") in {"failed", "unreachable"}:
            failure = event

if not failure:
    sys.exit(1)

task = failure.get("task", "")
status = failure.get("status", "")
detail = failure.get("msg") or failure.get("stderr") or failure.get("stdout") or ""
detail = " ".join(detail.split())
print(task)
print(status)
print(detail)
PY
)" || true

  if [[ -n "$summary" ]]; then
    task="$(printf '%s\n' "$summary" | sed -n '1p')"
    status="$(printf '%s\n' "$summary" | sed -n '2p')"
    detail="$(printf '%s\n' "$summary" | sed -n '3p')"
  fi

  task="$(truncate_text "$task" 180)"
  detail="$(truncate_text "$detail" 350)"
  hint="$(suggest_failure_hint "$phase" "$task" "$detail")"

  if [[ -n "$task" ]]; then
    echo "ERROR: Phase '$phase' failed at task: $task" >&2
  else
    echo "ERROR: Phase '$phase' failed." >&2
  fi

  if [[ -n "$status" ]]; then
    echo "Status: $status" >&2
  fi

  if [[ -n "$detail" ]]; then
    echo "Reason: $detail" >&2
  fi

  if [[ -n "$hint" ]]; then
    echo "Next: $hint" >&2
  fi
  echo "Log: $LABSTRAP_LOG_FILE" >&2
}

init_logging() {
  local command_name="$1"
  local configured_dir="${LABSTRAP_LOG_DIR:-/var/log/labstrap}"
  local log_dir="$configured_dir"
  local timestamp

  if ! mkdir -p "$log_dir" >/dev/null 2>&1; then
    log_dir="/tmp/labstrap"
    mkdir -p "$log_dir"
  fi

  timestamp="$(date -u +"%Y%m%dT%H%M%SZ")"
  LABSTRAP_LOG_FILE="$log_dir/${timestamp}-${command_name:-unknown}-$$.jsonl"
  : > "$LABSTRAP_LOG_FILE"
  export LABSTRAP_LOG_FILE

  log_event "INFO" "log.start" "Structured logging initialized" "log_file" "$LABSTRAP_LOG_FILE"
}

print_usage() {
  cat <<USAGE
Usage:
  labstrap init
  labstrap harden
  labstrap extras [component|all]
  labstrap allow-key <path_to_pubkey>
  labstrap doctor [--fix]
  labstrap status
USAGE
}

banner() {
  echo
  echo "== $1 =="
}

require_root() {
  if [[ "$EUID" -ne 0 ]]; then
    log_event "ERROR" "auth.not_root" "Command requires sudo/root"
    echo "ERROR: This command must be run with sudo/root." >&2
    exit 1
  fi
}

require_command() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 || {
    log_event "ERROR" "dependency.missing" "Required command not found" "dependency" "$cmd"
    echo "ERROR: Missing required command: $cmd" >&2
    exit 1
  }
}

config_value() {
  local key="$1"
  awk -v key="$key" '$1 == key":" {print $2; exit}' "$CONFIG_PATH"
}

config_nested_value() {
  local section="$1"
  local key="$2"
  awk -v section="$section" -v key="$key" '
    $0 ~ "^" section ":[[:space:]]*$" {in_section=1; next}
    in_section && $0 ~ "^[^[:space:]]" {in_section=0}
    in_section && $1 == key":" {print $2; exit}
  ' "$CONFIG_PATH"
}

run_preflight() {
  local phase="$1"
  log_event "INFO" "preflight.start" "Running preflight checks" "phase" "$phase"
  if LABSTRAP_CONFIG="$CONFIG_PATH" LABSTRAP_LOG_FILE="$LABSTRAP_LOG_FILE" "$PRECHECK_SCRIPT" "$phase"; then
    log_event "INFO" "preflight.success" "Preflight checks passed" "phase" "$phase"
    return 0
  fi

  log_event "ERROR" "preflight.failed" "Preflight checks failed" "phase" "$phase"
  print_preflight_failure_summary "$phase"
  return 1
}

run_ansible_phase() {
  local action="$1"
  shift || true

  require_command ansible-playbook
  log_event "INFO" "ansible.start" "Starting ansible phase" "phase" "$action"

  local args=(
    -i "$ANSIBLE_DIR/inventory.ini"
    "$ANSIBLE_DIR/playbook.yml"
    -e "labstrap_action=$action"
    -e "@$CONFIG_PATH"
  )

  if [[ "$action" == "extras" ]]; then
    local component="${1:-all}"
    args+=( -e "extras_component=$component" )
  fi

  if ANSIBLE_CALLBACK_PLUGINS="$ANSIBLE_DIR/callback_plugins${ANSIBLE_CALLBACK_PLUGINS:+:$ANSIBLE_CALLBACK_PLUGINS}" \
     ANSIBLE_STDOUT_CALLBACK=labstrap_jsonl \
     ANSIBLE_LOAD_CALLBACK_PLUGINS=1 \
     LABSTRAP_LOG_FILE="$LABSTRAP_LOG_FILE" \
     LABSTRAP_LOG_COMMAND="$LOG_COMMAND" \
     LABSTRAP_PHASE="$action" \
     ansible-playbook "${args[@]}"; then
    log_event "INFO" "ansible.success" "Ansible phase completed" "phase" "$action"
    return 0
  fi

  log_event "ERROR" "ansible.failed" "Ansible phase failed" "phase" "$action"
  print_ansible_failure_summary "$action"
  return 1
}

run_allow_key() {
  local key_file="$1"
  local user_name
  local home_dir
  local key_line

  log_event "INFO" "allow_key.start" "Processing SSH public key" "key_path" "$key_file"

  [[ -f "$key_file" ]] || {
    log_event "ERROR" "allow_key.invalid_path" "Public key file not found" "key_path" "$key_file"
    echo "ERROR: Public key file not found: $key_file" >&2
    exit 1
  }

  key_line="$(awk 'NF {print; exit}' "$key_file")"
  [[ -n "$key_line" ]] || {
    log_event "ERROR" "allow_key.empty_key" "Public key file is empty" "key_path" "$key_file"
    echo "ERROR: Public key file is empty: $key_file" >&2
    exit 1
  }

  case "$key_line" in
    ssh-*|ecdsa-*|sk-*) ;;
    *)
      log_event "ERROR" "allow_key.invalid_format" "Public key format appears invalid" "key_path" "$key_file"
      echo "ERROR: File does not appear to contain a valid SSH public key." >&2
      exit 1
      ;;
  esac

  user_name="$(config_value user)"
  [[ -n "$user_name" ]] || {
    log_event "ERROR" "allow_key.config_missing_user" "Unable to read user from config"
    echo "ERROR: Unable to read user from config." >&2
    exit 1
  }

  home_dir="$(getent passwd "$user_name" | cut -d: -f6)"
  [[ -n "$home_dir" && -d "$home_dir" ]] || {
    log_event "ERROR" "allow_key.user_home_missing" "Target user home directory missing" "user" "$user_name"
    echo "ERROR: Target user home directory not found for user '$user_name'." >&2
    exit 1
  }

  install -d -m 0700 -o "$user_name" -g "$user_name" "$home_dir/.ssh"
  touch "$home_dir/.ssh/authorized_keys"
  chown "$user_name:$user_name" "$home_dir/.ssh/authorized_keys"
  chmod 0600 "$home_dir/.ssh/authorized_keys"

  if grep -qxF "$key_line" "$home_dir/.ssh/authorized_keys"; then
    log_event "INFO" "allow_key.noop" "SSH key already present" "user" "$user_name"
    echo "allow-key: key already present for user '$user_name'."
    return
  fi

  printf '%s\n' "$key_line" >> "$home_dir/.ssh/authorized_keys"
  chown "$user_name:$user_name" "$home_dir/.ssh/authorized_keys"
  chmod 0600 "$home_dir/.ssh/authorized_keys"
  log_event "INFO" "allow_key.added" "SSH key added" "user" "$user_name"
  echo "allow-key: key added for user '$user_name'."
}

status_check() {
  local label="$1"
  local cmd="$2"

  if bash -c "$cmd" >/dev/null 2>&1; then
    log_event "INFO" "status.check" "Status check passed" "check" "$label" "result" "PASS"
    echo "[PASS] $label"
    return 0
  fi

  log_event "ERROR" "status.check" "Status check failed" "check" "$label" "result" "FAIL"
  echo "[FAIL] $label"
  return 1
}

doctor_record() {
  local level="$1"
  local label="$2"
  local detail="${3:-}"

  case "$level" in
    PASS)
      echo "[PASS] $label"
      log_event "INFO" "doctor.check" "Doctor check passed" "check" "$label" "result" "PASS"
      ;;
    WARN)
      echo "[WARN] $label${detail:+ - $detail}"
      log_event "WARN" "doctor.check" "Doctor check warning" "check" "$label" "result" "WARN" "detail" "$detail"
      ;;
    FAIL)
      echo "[FAIL] $label${detail:+ - $detail}"
      log_event "ERROR" "doctor.check" "Doctor check failed" "check" "$label" "result" "FAIL" "detail" "$detail"
      ;;
    FIXED)
      echo "[FIXED] $label${detail:+ - $detail}"
      log_event "INFO" "doctor.check" "Doctor check fixed" "check" "$label" "result" "FIXED" "detail" "$detail"
      ;;
  esac
}

run_doctor() {
  local fix_mode="${1:-0}"
  local user_name=""
  local user_home=""
  local fail_count=0
  local warn_count=0
  local pass_count=0
  local fix_count=0
  local detail=""

  banner "labstrap doctor"
  if [[ "$fix_mode" == "1" ]]; then
    echo "fix mode: enabled"
  else
    echo "fix mode: disabled"
  fi

  if command -v ansible-playbook >/dev/null 2>&1; then
    doctor_record "PASS" "ansible-playbook installed"
    pass_count=$((pass_count + 1))
  else
    doctor_record "FAIL" "ansible-playbook installed" "install dependencies via: sudo ./install.sh"
    fail_count=$((fail_count + 1))
  fi

  user_name="$(config_value user)"
  if [[ -z "$user_name" ]]; then
    doctor_record "FAIL" "config user value" "missing 'user:' in $CONFIG_PATH"
    fail_count=$((fail_count + 1))
  elif id "$user_name" >/dev/null 2>&1; then
    user_home="$(getent passwd "$user_name" | cut -d: -f6)"
    doctor_record "PASS" "provisioning user exists" "$user_name"
    pass_count=$((pass_count + 1))
  else
    doctor_record "FAIL" "provisioning user exists" "run: sudo labstrap init"
    fail_count=$((fail_count + 1))
  fi

  if [[ -n "$user_home" ]]; then
    if [[ -d "$user_home/.ssh" ]]; then
      doctor_record "PASS" "user .ssh directory exists" "$user_home/.ssh"
      pass_count=$((pass_count + 1))
    else
      doctor_record "WARN" "user .ssh directory exists" "will be created by harden/allow-key"
      warn_count=$((warn_count + 1))
    fi

    if [[ -s "$user_home/.ssh/authorized_keys" ]]; then
      doctor_record "PASS" "authorized_keys has at least one key"
      pass_count=$((pass_count + 1))
    else
      doctor_record "FAIL" "authorized_keys has at least one key" "run: sudo labstrap allow-key /path/to/key.pub"
      fail_count=$((fail_count + 1))
    fi

    if [[ -f "$user_home/.npmrc" ]]; then
      detail="$(grep -E '^[[:space:]]*(prefix|globalconfig)[[:space:]]*=' "$user_home/.npmrc" || true)"
      if [[ -n "$detail" ]]; then
        if [[ "$fix_mode" == "1" ]]; then
          sed -i.bak -E '/^[[:space:]]*(prefix|globalconfig)[[:space:]]*=/d' "$user_home/.npmrc"
          chown "$user_name:$user_name" "$user_home/.npmrc" || true
          doctor_record "FIXED" "npmrc nvm compatibility" "removed prefix/globalconfig from $user_home/.npmrc"
          fix_count=$((fix_count + 1))
        else
          doctor_record "FAIL" "npmrc nvm compatibility" "remove prefix/globalconfig lines from $user_home/.npmrc or run: sudo labstrap doctor --fix"
          fail_count=$((fail_count + 1))
        fi
      else
        doctor_record "PASS" "npmrc nvm compatibility"
        pass_count=$((pass_count + 1))
      fi
    else
      doctor_record "PASS" "npmrc nvm compatibility" "no ~/.npmrc override found"
      pass_count=$((pass_count + 1))
    fi

    if [[ -d "/home/linuxbrew/.linuxbrew" ]]; then
      if sudo -u "$user_name" test -w /home/linuxbrew/.linuxbrew; then
        doctor_record "PASS" "linuxbrew path writable by user" "/home/linuxbrew/.linuxbrew"
        pass_count=$((pass_count + 1))
      else
        if [[ "$fix_mode" == "1" ]]; then
          mkdir -p /home/linuxbrew/.linuxbrew
          chown -R "$user_name:$user_name" /home/linuxbrew
          doctor_record "FIXED" "linuxbrew path writable by user" "updated ownership under /home/linuxbrew"
          fix_count=$((fix_count + 1))
        else
          doctor_record "FAIL" "linuxbrew path writable by user" "run: sudo chown -R $user_name:$user_name /home/linuxbrew or run: sudo labstrap doctor --fix"
          fail_count=$((fail_count + 1))
        fi
      fi
    else
      if [[ "$fix_mode" == "1" ]]; then
        mkdir -p /home/linuxbrew/.linuxbrew
        chown -R "$user_name:$user_name" /home/linuxbrew
        doctor_record "FIXED" "linuxbrew path exists" "created /home/linuxbrew/.linuxbrew"
        fix_count=$((fix_count + 1))
      else
        doctor_record "WARN" "linuxbrew path exists" "will be created during homebrew install"
        warn_count=$((warn_count + 1))
      fi
    fi
  fi

  if [[ -f /etc/ssh/sshd_config ]]; then
    doctor_record "PASS" "sshd_config exists"
    pass_count=$((pass_count + 1))
  else
    doctor_record "FAIL" "sshd_config exists" "install openssh-server or run: sudo labstrap harden"
    fail_count=$((fail_count + 1))
  fi

  if [[ -d /run/sshd ]]; then
    doctor_record "PASS" "/run/sshd exists"
    pass_count=$((pass_count + 1))
  else
    if [[ "$fix_mode" == "1" ]]; then
      mkdir -p /run/sshd
      chmod 755 /run/sshd
      doctor_record "FIXED" "/run/sshd exists" "created /run/sshd"
      fix_count=$((fix_count + 1))
    else
      doctor_record "WARN" "/run/sshd exists" "run: sudo mkdir -p /run/sshd && sudo chmod 755 /run/sshd"
      warn_count=$((warn_count + 1))
    fi
  fi

  if /usr/sbin/sshd -t -f /etc/ssh/sshd_config >/dev/null 2>&1; then
    doctor_record "PASS" "sshd configuration validates"
    pass_count=$((pass_count + 1))
  else
    detail="$(/usr/sbin/sshd -t -f /etc/ssh/sshd_config 2>&1 || true)"
    doctor_record "FAIL" "sshd configuration validates" "$(truncate_text "$detail" 220)"
    fail_count=$((fail_count + 1))
  fi

  if systemctl is-active --quiet ssh || systemctl is-active --quiet sshd; then
    doctor_record "PASS" "ssh service is active"
    pass_count=$((pass_count + 1))
  else
    doctor_record "WARN" "ssh service is active" "start with: sudo systemctl start ssh || sudo systemctl start sshd"
    warn_count=$((warn_count + 1))
  fi

  if command -v tailscale >/dev/null 2>&1; then
    doctor_record "PASS" "tailscale installed"
    pass_count=$((pass_count + 1))
  else
    doctor_record "WARN" "tailscale installed" "installed by harden phase"
    warn_count=$((warn_count + 1))
  fi

  if [[ -n "$user_home" ]]; then
    if [[ "$(config_nested_value extras claudecode)" == "true" ]]; then
      if [[ -x "$user_home/.npm-global/bin/claude" || -x "$user_home/.local/bin/claude" ]]; then
        doctor_record "PASS" "extra claudecode installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra claudecode installed" "run: sudo labstrap extras claudecode"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras kimi)" == "true" ]]; then
      if [[ -x "$user_home/.local/bin/kimi" ]]; then
        doctor_record "PASS" "extra kimi installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra kimi installed" "run: sudo labstrap extras kimi"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras camoufox)" == "true" ]]; then
      if [[ -x "$user_home/.local/bin/camoufox" && -x "$user_home/.venvs/camoufox/bin/python" ]]; then
        doctor_record "PASS" "extra camoufox installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra camoufox installed" "run: sudo labstrap extras camoufox"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras cargo)" == "true" ]]; then
      if [[ -x "$user_home/.cargo/bin/cargo" || -x "$user_home/.local/bin/cargo" ]]; then
        doctor_record "PASS" "extra cargo installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra cargo installed" "run: sudo labstrap extras cargo"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras tsx)" == "true" ]]; then
      if [[ -x "$user_home/.npm-global/bin/tsx" || -x "$user_home/.local/bin/tsx" ]]; then
        doctor_record "PASS" "extra tsx installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra tsx installed" "run: sudo labstrap extras tsx"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras openclaw)" == "true" ]]; then
      if [[ -x "$user_home/.openclaw/bin/openclaw" || -x "$user_home/.npm-global/bin/openclaw" ]]; then
        doctor_record "PASS" "extra openclaw installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra openclaw installed" "run: sudo labstrap extras openclaw"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras bun)" == "true" ]]; then
      if [[ -x "$user_home/.bun/bin/bun" || -x "$user_home/.local/bin/bun" ]]; then
        doctor_record "PASS" "extra bun installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra bun installed" "run: sudo labstrap extras bun"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras whisper)" == "true" ]]; then
      if [[ -x "$user_home/.venvs/whisper/bin/whisper" ]]; then
        doctor_record "PASS" "extra whisper installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra whisper installed" "run: sudo labstrap extras whisper"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras rbw)" == "true" ]]; then
      if [[ -x "$user_home/.linuxbrew/bin/rbw" || -x "/home/linuxbrew/.linuxbrew/bin/rbw" || -x "$user_home/.local/bin/rbw" ]]; then
        doctor_record "PASS" "extra rbw installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra rbw installed" "run: sudo labstrap extras rbw"
        fail_count=$((fail_count + 1))
      fi
    fi
  fi

  echo
  echo "doctor summary: pass=$pass_count warn=$warn_count fail=$fail_count fixed=$fix_count"
  if [[ "$fail_count" -gt 0 ]]; then
    echo "doctor status: FAIL"
    return 1
  fi

  if [[ "$warn_count" -gt 0 ]]; then
    echo "doctor status: WARN"
    return 0
  fi

  echo "doctor status: OK"
  return 0
}

run_status() {
  local user_name
  local user_home
  local user_home_q
  local ssh_port
  local extras_homebrew
  local extras_zsh
  local extras_dokploy
  local extras_starship
  local extras_yazi
  local extras_node
  local extras_codex
  local extras_claudecode
  local extras_kimi
  local extras_camoufox
  local extras_cargo
  local extras_pm2
  local extras_pnpm
  local extras_tcs
  local extras_tsx
  local extras_openclaw
  local extras_clawvault
  local extras_bun
  local extras_whisper
  local extras_rbw
  local failures=0

  user_name="$(config_value user)"
  user_home="$(getent passwd "$user_name" 2>/dev/null | cut -d: -f6)"
  [[ -n "$user_home" ]] || user_home="/home/$user_name"
  printf -v user_home_q "%q" "$user_home"
  ssh_port="$(config_nested_value ssh port)"
  extras_homebrew="$(config_nested_value extras homebrew)"
  extras_zsh="$(config_nested_value extras zsh)"
  extras_dokploy="$(config_nested_value extras dokploy)"
  extras_starship="$(config_nested_value extras starship)"
  extras_yazi="$(config_nested_value extras yazi)"
  extras_node="$(config_nested_value extras node)"
  extras_codex="$(config_nested_value extras codex)"
  extras_claudecode="$(config_nested_value extras claudecode)"
  extras_kimi="$(config_nested_value extras kimi)"
  extras_camoufox="$(config_nested_value extras camoufox)"
  extras_cargo="$(config_nested_value extras cargo)"
  extras_pm2="$(config_nested_value extras pm2)"
  extras_pnpm="$(config_nested_value extras pnpm)"
  extras_tcs="$(config_nested_value extras tcs)"
  extras_tsx="$(config_nested_value extras tsx)"
  extras_openclaw="$(config_nested_value extras openclaw)"
  extras_clawvault="$(config_nested_value extras clawvault)"
  extras_bun="$(config_nested_value extras bun)"
  extras_whisper="$(config_nested_value extras whisper)"
  extras_rbw="$(config_nested_value extras rbw)"

  [[ -n "$ssh_port" ]] || ssh_port="22222"

  banner "labstrap status"

  status_check "SSH service running" "systemctl is-active --quiet ssh || systemctl is-active --quiet sshd" || failures=$((failures + 1))
  status_check "SSH listening on port $ssh_port" "ss -ltn | awk '{print \$4}' | grep -Eq '[:.]$ssh_port$'" || failures=$((failures + 1))
  status_check "UFW active" "ufw status | grep -q 'Status: active'" || failures=$((failures + 1))
  status_check "UFW allows tailscale0" "ufw status | grep -q 'tailscale0'" || failures=$((failures + 1))
  status_check "Tailscale is up" "tailscale status --json | grep -Eq '\"BackendState\"[[:space:]]*:[[:space:]]*\"Running\"'" || failures=$((failures + 1))
  status_check "Service: fail2ban running" "systemctl is-active --quiet fail2ban" || failures=$((failures + 1))
  status_check "Service: tailscaled running" "systemctl is-active --quiet tailscaled" || failures=$((failures + 1))

  if [[ "$extras_homebrew" == "true" ]]; then
    status_check "Extra: homebrew installed" "[[ -x $user_home_q/.linuxbrew/bin/brew || -x /home/linuxbrew/.linuxbrew/bin/brew ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_zsh" == "true" ]]; then
    status_check "Extra: zsh installed" "command -v zsh" || failures=$((failures + 1))
  fi

  if [[ "$extras_dokploy" == "true" ]]; then
    status_check "Extra: dokploy service exists" "docker service inspect dokploy >/dev/null 2>&1" || failures=$((failures + 1))
  fi

  if [[ "$extras_starship" == "true" ]]; then
    status_check "Extra: starship installed" "[[ -x $user_home_q/.local/bin/starship ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_yazi" == "true" ]]; then
    status_check "Extra: yazi installed" "[[ -x $user_home_q/.linuxbrew/bin/yazi || -x /home/linuxbrew/.linuxbrew/bin/yazi ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_node" == "true" ]]; then
    status_check "Extra: node LTS installed" "ls $user_home_q/.nvm/versions/node/*/bin/node >/dev/null 2>&1" || failures=$((failures + 1))
  fi

  if [[ "$extras_codex" == "true" ]]; then
    status_check "Extra: codex installed" "[[ -x $user_home_q/.npm-global/bin/codex ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_claudecode" == "true" ]]; then
    status_check "Extra: claude code installed" "[[ -x $user_home_q/.npm-global/bin/claude || -x $user_home_q/.local/bin/claude ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_kimi" == "true" ]]; then
    status_check "Extra: kimi installed" "[[ -x $user_home_q/.local/bin/kimi ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_camoufox" == "true" ]]; then
    status_check "Extra: camoufox installed" "[[ -x $user_home_q/.local/bin/camoufox && -x $user_home_q/.venvs/camoufox/bin/python ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_cargo" == "true" ]]; then
    status_check "Extra: cargo installed" "[[ -x $user_home_q/.cargo/bin/cargo || -x $user_home_q/.local/bin/cargo ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_pm2" == "true" ]]; then
    status_check "Extra: pm2 installed" "[[ -x $user_home_q/.npm-global/bin/pm2 ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_pnpm" == "true" ]]; then
    status_check "Extra: pnpm installed" "[[ -x $user_home_q/.npm-global/bin/pnpm ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_tcs" == "true" ]]; then
    status_check "Extra: tcs installed" "[[ -x $user_home_q/.local/bin/tcs ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_tsx" == "true" ]]; then
    status_check "Extra: tsx installed" "[[ -x $user_home_q/.npm-global/bin/tsx || -x $user_home_q/.local/bin/tsx ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_openclaw" == "true" ]]; then
    status_check "Extra: openclaw installed" "[[ -x $user_home_q/.openclaw/bin/openclaw || -x $user_home_q/.npm-global/bin/openclaw ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_clawvault" == "true" ]]; then
    status_check "Extra: clawvault installed" "[[ -x $user_home_q/.npm-global/bin/clawvault ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_bun" == "true" ]]; then
    status_check "Extra: bun installed" "[[ -x $user_home_q/.bun/bin/bun || -x $user_home_q/.local/bin/bun ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_whisper" == "true" ]]; then
    status_check "Extra: whisper virtualenv installed" "[[ -x $user_home_q/.venvs/whisper/bin/whisper && ( -L /usr/local/bin/whisper || -x $user_home_q/.local/bin/whisper ) ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_rbw" == "true" ]]; then
    status_check "Extra: rbw installed" "[[ -x $user_home_q/.linuxbrew/bin/rbw || -x /home/linuxbrew/.linuxbrew/bin/rbw || -x $user_home_q/.local/bin/rbw ]]" || failures=$((failures + 1))
  fi

  echo
  if [[ "$failures" -eq 0 ]]; then
    echo "status: OK"
    return 0
  fi

  echo "status: FAIL ($failures checks failed)"
  return 1
}

main() {
  local command="${1:-}"
  LOG_COMMAND="$command"
  init_logging "$command"
  log_event "INFO" "command.start" "Command execution started" "cmd_name" "${command:-<none>}"

  [[ -f "$CONFIG_PATH" ]] || {
    log_event "ERROR" "config.missing" "Configuration file not found" "config_path" "$CONFIG_PATH"
    echo "ERROR: Missing configuration file: $CONFIG_PATH" >&2
    exit 1
  }

  case "$command" in
    init)
      require_root
      banner "Phase 1: init"
      run_preflight init
      run_ansible_phase init
      ;;

    harden)
      require_root
      banner "Phase 2: harden"
      run_preflight harden
      run_ansible_phase harden
      ;;

    extras)
      require_root
      local component="${2:-all}"
      case "$component" in
        all|homebrew|dokploy|zsh|ohmyzsh|starship|yazi|node|codex|claudecode|kimi|camoufox|cargo|pm2|pnpm|tcs|tsx|openclaw|clawvault|bun|whisper|rbw|dotfiles) ;;
        *)
          echo "ERROR: Invalid extras component '$component'." >&2
          print_usage
          exit 1
          ;;
      esac

      banner "Phase 3: extras ($component)"
      run_preflight extras
      run_ansible_phase extras "$component"
      ;;

    allow-key)
      require_root
      local key_path="${2:-}"
      [[ -n "$key_path" ]] || {
        echo "ERROR: Missing key path." >&2
        print_usage
        exit 1
      }

      banner "allow-key"
      run_preflight allow-key
      run_allow_key "$key_path"
      ;;

    doctor)
      require_root
      local doctor_arg="${2:-}"
      local fix_mode="0"
      case "$doctor_arg" in
        "")
          ;;
        --fix)
          fix_mode="1"
          ;;
        *)
          echo "ERROR: Invalid doctor option '$doctor_arg'." >&2
          echo "Usage: labstrap doctor [--fix]" >&2
          exit 1
          ;;
      esac
      run_doctor "$fix_mode"
      ;;

    status)
      run_status
      ;;

    -h|--help|help)
      log_event "INFO" "command.help" "Displaying help output"
      print_usage
      ;;

    "")
      log_event "ERROR" "command.empty" "No command supplied"
      print_usage
      exit 1
      ;;

    *)
      log_event "ERROR" "command.unknown" "Unknown command" "cmd_name" "$command"
      echo "ERROR: Unknown command '$command'." >&2
      print_usage
      exit 1
      ;;
  esac

  log_event "INFO" "command.success" "Command execution completed" "cmd_name" "$command"
}

main "$@"
