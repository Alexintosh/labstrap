doctor_record() {
  local level="$1"
  local label="$2"
  local detail="${3:-}"

  case "$level" in
    PASS)
      echo "[PASS] $label"
      log_event "INFO" "doctor.check" "Doctor check passed" "check" "$label" "result" "PASS"
      ;;
    WARN)
      echo "[WARN] $label${detail:+ - $detail}"
      log_event "WARN" "doctor.check" "Doctor check warning" "check" "$label" "result" "WARN" "detail" "$detail"
      ;;
    FAIL)
      echo "[FAIL] $label${detail:+ - $detail}"
      log_event "ERROR" "doctor.check" "Doctor check failed" "check" "$label" "result" "FAIL" "detail" "$detail"
      ;;
    FIXED)
      echo "[FIXED] $label${detail:+ - $detail}"
      log_event "INFO" "doctor.check" "Doctor check fixed" "check" "$label" "result" "FIXED" "detail" "$detail"
      ;;
  esac
}

run_doctor() {
  local fix_mode="${1:-0}"
  local user_name=""
  local user_home=""
  local user_shell=""
  local fail_count=0
  local warn_count=0
  local pass_count=0
  local fix_count=0
  local detail=""

  banner "labstrap doctor"
  if [[ "$fix_mode" == "1" ]]; then
    echo "fix mode: enabled"
  else
    echo "fix mode: disabled"
  fi

  if command -v ansible-playbook >/dev/null 2>&1; then
    doctor_record "PASS" "ansible-playbook installed"
    pass_count=$((pass_count + 1))
  else
    doctor_record "FAIL" "ansible-playbook installed" "install dependencies via: sudo ./install.sh"
    fail_count=$((fail_count + 1))
  fi

  user_name="$(config_value user)"
  if [[ -z "$user_name" ]]; then
    doctor_record "FAIL" "config user value" "missing 'user:' in $CONFIG_PATH"
    fail_count=$((fail_count + 1))
  elif id "$user_name" >/dev/null 2>&1; then
    user_home="$(getent passwd "$user_name" | cut -d: -f6)"
    user_shell="$(target_user_shell "$user_name")"
    doctor_record "PASS" "provisioning user exists" "$user_name"
    pass_count=$((pass_count + 1))
  else
    doctor_record "FAIL" "provisioning user exists" "run: sudo labstrap init"
    fail_count=$((fail_count + 1))
  fi

  if [[ -n "$user_home" ]]; then
    if [[ -d "$user_home/.ssh" ]]; then
      doctor_record "PASS" "user .ssh directory exists" "$user_home/.ssh"
      pass_count=$((pass_count + 1))
    else
      doctor_record "WARN" "user .ssh directory exists" "will be created by harden/allow-key"
      warn_count=$((warn_count + 1))
    fi

    if [[ -s "$user_home/.ssh/authorized_keys" ]]; then
      doctor_record "PASS" "authorized_keys has at least one key"
      pass_count=$((pass_count + 1))
    else
      doctor_record "FAIL" "authorized_keys has at least one key" "run: sudo labstrap allow-key /path/to/key.pub"
      fail_count=$((fail_count + 1))
    fi

    if [[ -f "$user_home/.npmrc" ]]; then
      detail="$(grep -E '^[[:space:]]*(prefix|globalconfig)[[:space:]]*=' "$user_home/.npmrc" || true)"
      if [[ -n "$detail" ]]; then
        if [[ "$fix_mode" == "1" ]]; then
          sed -i.bak -E '/^[[:space:]]*(prefix|globalconfig)[[:space:]]*=/d' "$user_home/.npmrc"
          chown "$user_name:$user_name" "$user_home/.npmrc" || true
          doctor_record "FIXED" "npmrc nvm compatibility" "removed prefix/globalconfig from $user_home/.npmrc"
          fix_count=$((fix_count + 1))
        else
          doctor_record "FAIL" "npmrc nvm compatibility" "remove prefix/globalconfig lines from $user_home/.npmrc or run: sudo labstrap doctor --fix"
          fail_count=$((fail_count + 1))
        fi
      else
        doctor_record "PASS" "npmrc nvm compatibility"
        pass_count=$((pass_count + 1))
      fi
    else
      doctor_record "PASS" "npmrc nvm compatibility" "no ~/.npmrc override found"
      pass_count=$((pass_count + 1))
    fi

    if [[ -d "/home/linuxbrew/.linuxbrew" ]]; then
      if sudo -u "$user_name" test -w /home/linuxbrew/.linuxbrew; then
        doctor_record "PASS" "linuxbrew path writable by user" "/home/linuxbrew/.linuxbrew"
        pass_count=$((pass_count + 1))
      else
        if [[ "$fix_mode" == "1" ]]; then
          mkdir -p /home/linuxbrew/.linuxbrew
          chown -R "$user_name:$user_name" /home/linuxbrew
          doctor_record "FIXED" "linuxbrew path writable by user" "updated ownership under /home/linuxbrew"
          fix_count=$((fix_count + 1))
        else
          doctor_record "FAIL" "linuxbrew path writable by user" "run: sudo chown -R $user_name:$user_name /home/linuxbrew or run: sudo labstrap doctor --fix"
          fail_count=$((fail_count + 1))
        fi
      fi
    else
      if [[ "$fix_mode" == "1" ]]; then
        mkdir -p /home/linuxbrew/.linuxbrew
        chown -R "$user_name:$user_name" /home/linuxbrew
        doctor_record "FIXED" "linuxbrew path exists" "created /home/linuxbrew/.linuxbrew"
        fix_count=$((fix_count + 1))
      else
        doctor_record "WARN" "linuxbrew path exists" "will be created during homebrew install"
        warn_count=$((warn_count + 1))
      fi
    fi
  fi

  if [[ -f /etc/ssh/sshd_config ]]; then
    doctor_record "PASS" "sshd_config exists"
    pass_count=$((pass_count + 1))
  else
    doctor_record "FAIL" "sshd_config exists" "install openssh-server or run: sudo labstrap harden"
    fail_count=$((fail_count + 1))
  fi

  if [[ -d /run/sshd ]]; then
    doctor_record "PASS" "/run/sshd exists"
    pass_count=$((pass_count + 1))
  else
    if [[ "$fix_mode" == "1" ]]; then
      mkdir -p /run/sshd
      chmod 755 /run/sshd
      doctor_record "FIXED" "/run/sshd exists" "created /run/sshd"
      fix_count=$((fix_count + 1))
    else
      doctor_record "WARN" "/run/sshd exists" "run: sudo mkdir -p /run/sshd && sudo chmod 755 /run/sshd"
      warn_count=$((warn_count + 1))
    fi
  fi

  if /usr/sbin/sshd -t -f /etc/ssh/sshd_config >/dev/null 2>&1; then
    doctor_record "PASS" "sshd configuration validates"
    pass_count=$((pass_count + 1))
  else
    detail="$(/usr/sbin/sshd -t -f /etc/ssh/sshd_config 2>&1 || true)"
    doctor_record "FAIL" "sshd configuration validates" "$(truncate_text "$detail" 220)"
    fail_count=$((fail_count + 1))
  fi

  if systemctl is-active --quiet ssh || systemctl is-active --quiet sshd; then
    doctor_record "PASS" "ssh service is active"
    pass_count=$((pass_count + 1))
  else
    doctor_record "WARN" "ssh service is active" "start with: sudo systemctl start ssh || sudo systemctl start sshd"
    warn_count=$((warn_count + 1))
  fi

  if command -v tailscale >/dev/null 2>&1; then
    doctor_record "PASS" "tailscale installed"
    pass_count=$((pass_count + 1))
  else
    doctor_record "WARN" "tailscale installed" "installed by harden phase"
    warn_count=$((warn_count + 1))
  fi

  if [[ -n "$user_home" ]]; then
    if [[ "$(config_nested_value extras claudecode)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" claude; then
        doctor_record "PASS" "extra claudecode installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra claudecode installed" "run: sudo labstrap extras claudecode"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras kimi)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" kimi; then
        doctor_record "PASS" "extra kimi installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra kimi installed" "run: sudo labstrap extras kimi"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras camoufox)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" camoufox; then
        doctor_record "PASS" "extra camoufox installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra camoufox installed" "run: sudo labstrap extras camoufox"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras cargo)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" cargo; then
        doctor_record "PASS" "extra cargo installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra cargo installed" "run: sudo labstrap extras cargo"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras tsx)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" tsx; then
        doctor_record "PASS" "extra tsx installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra tsx installed" "run: sudo labstrap extras tsx"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras openclaw)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" openclaw; then
        doctor_record "PASS" "extra openclaw installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra openclaw installed" "run: sudo labstrap extras openclaw"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras bun)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" bun; then
        doctor_record "PASS" "extra bun installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra bun installed" "run: sudo labstrap extras bun"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras whisper)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" whisper; then
        doctor_record "PASS" "extra whisper installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra whisper installed" "run: sudo labstrap extras whisper"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras rbw)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" rbw; then
        doctor_record "PASS" "extra rbw installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra rbw installed" "run: sudo labstrap extras rbw"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras llamacpp)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" llama-cli; then
        doctor_record "PASS" "extra llamacpp installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra llamacpp installed" "run: sudo labstrap extras llamacpp"
        fail_count=$((fail_count + 1))
      fi
    fi

    if [[ "$(config_nested_value extras herdr)" == "true" ]]; then
      if user_shell_command_available "$user_name" "$user_home" "$user_shell" herdr; then
        doctor_record "PASS" "extra herdr installed"
        pass_count=$((pass_count + 1))
      else
        doctor_record "FAIL" "extra herdr installed" "run: sudo labstrap extras herdr"
        fail_count=$((fail_count + 1))
      fi
    fi
  fi

  echo
  echo "doctor summary: pass=$pass_count warn=$warn_count fail=$fail_count fixed=$fix_count"
  if [[ "$fail_count" -gt 0 ]]; then
    echo "doctor status: FAIL"
    return 1
  fi

  if [[ "$warn_count" -gt 0 ]]; then
    echo "doctor status: WARN"
    return 0
  fi

  echo "doctor status: OK"
  return 0
}

