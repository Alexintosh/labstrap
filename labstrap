#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source_path="${BASH_SOURCE[0]}"
  while [[ -h "$source_path" ]]; do
    local source_dir
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    source_path="$(readlink "$source_path")"
    [[ "$source_path" != /* ]] && source_path="$source_dir/$source_path"
  done
  cd -P "$(dirname "$source_path")" && pwd
}

ROOT_DIR="$(resolve_script_path)"
ANSIBLE_DIR="$ROOT_DIR/ansible"
PRECHECK_SCRIPT="$ROOT_DIR/checks/preflight.sh"
DEFAULT_CONFIG="$ROOT_DIR/defaults/config.yml"
CONFIG_PATH="${LABSTRAP_CONFIG:-$DEFAULT_CONFIG}"
LABSTRAP_LOG_FILE="${LABSTRAP_LOG_FILE:-}"
LOG_COMMAND=""
EXTRAS_COMPONENTS=(
  homebrew
  dokploy
  zsh
  ohmyzsh
  starship
  yazi
  node
  codex
  claudecode
  kimi
  camoufox
  cargo
  pm2
  pnpm
  tcs
  tsx
  openclaw
  clawvault
  bun
  whisper
  rbw
  llamacpp
  herdr
  dotfiles
)

json_escape() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

log_event() {
  local level="$1"
  local event="$2"
  local message="$3"
  shift 3 || true

  local ts
  local json
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  json="{\"timestamp\":\"$ts\",\"level\":\"$(json_escape "$level")\",\"event\":\"$(json_escape "$event")\",\"command\":\"$(json_escape "$LOG_COMMAND")\",\"message\":\"$(json_escape "$message")\""

  while [[ "$#" -ge 2 ]]; do
    local key="$1"
    local value="$2"
    shift 2
    json="$json,\"$(json_escape "$key")\":\"$(json_escape "$value")\""
  done
  json="$json}"

  printf '%s\n' "$json"
  if [[ -n "$LABSTRAP_LOG_FILE" ]]; then
    printf '%s\n' "$json" >> "$LABSTRAP_LOG_FILE" || true
  fi
}

truncate_text() {
  local text="${1:-}"
  local limit="${2:-300}"
  if [[ ${#text} -le $limit ]]; then
    printf '%s' "$text"
    return
  fi
  printf '%s...' "${text:0:limit}"
}

suggest_failure_hint() {
  local phase="$1"
  local task="$2"
  local detail="$3"
  local user_name
  user_name="$(config_value user 2>/dev/null || true)"
  [[ -n "$user_name" ]] || user_name="<configured-user>"

  if [[ "$phase" == "harden" && "$task" == *"Ensure at least one SSH key exists"* ]]; then
    echo "No SSH key found for user '$user_name'. Run: sudo labstrap allow-key /path/to/key.pub ; then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$detail" == *"Tailscale is not active"* || "$task" == *"Verify Tailscale is connected"* ]]; then
    echo "Complete Tailscale authentication, then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$detail" == *"tailscale up timed out"* || "$task" == *"Bring up Tailscale"* ]]; then
    echo "Run: sudo tailscale up --ssh=false ; complete auth in browser ; then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$detail" == *"Homebrew is required"* ]]; then
    echo "Run the Homebrew component first: sudo labstrap extras homebrew"
    return
  fi

  if [[ "$detail" == *"/home/linuxbrew/.linuxbrew"* || "$detail" == *"Homebrew installation failed"* ]]; then
    echo "Homebrew issue. Fix ownership and retry: sudo mkdir -p /home/linuxbrew/.linuxbrew && sudo chown -R $(config_value user):$(config_value user) /home/linuxbrew ; then rerun: sudo labstrap extras homebrew (or interactive mode: sudo LABSTRAP_HOMEBREW_INTERACTIVE=1 labstrap extras homebrew)"
    return
  fi

  if [[ "$detail" == *"Node runtime is required"* ]]; then
    echo "Run the Node component first: sudo labstrap extras node"
    return
  fi

  if [[ "$phase" == "extras" && "$task" == *"Fail when one or more extras components failed"* ]]; then
    echo "Run: sudo labstrap doctor ; then rerun only failed components (example: sudo labstrap extras tsx)"
    return
  fi

  if [[ "$detail" == *".npmrc"* && "$detail" == *"incompatible with nvm"* ]]; then
    echo "Your ~/.npmrc has prefix/globalconfig incompatible with nvm. Remove those lines and rerun: sudo labstrap extras node && sudo labstrap extras codex"
    return
  fi

  if [[ "$detail" == *"Claude Code installation finished without producing"* ]]; then
    echo "Claude Code CLI install failed. Run: sudo labstrap extras node && sudo labstrap extras claudecode"
    return
  fi

  if [[ "$detail" == *"tsx installation finished without producing"* ]]; then
    echo "tsx install failed. Run: sudo labstrap extras node && sudo labstrap extras tsx"
    return
  fi

  if [[ "$detail" == *"Kimi installation finished without producing"* ]]; then
    echo "Kimi install failed. Verify internet access, then rerun: sudo labstrap extras kimi"
    return
  fi

  if [[ "$detail" == *"Camoufox installation did not create"* ]]; then
    echo "Camoufox install failed. Rerun with: sudo labstrap extras camoufox"
    return
  fi

  if [[ "$detail" == *"Cargo installation finished without producing"* ]]; then
    echo "Cargo install failed. Rerun with: sudo labstrap extras cargo"
    return
  fi

  if [[ "$detail" == *"OpenClaw installation finished without producing"* ]]; then
    echo "OpenClaw install failed. Rerun with: sudo labstrap extras openclaw"
    return
  fi

  if [[ "$detail" == *"bun installation finished without producing"* ]]; then
    echo "bun install failed. Rerun with: sudo labstrap extras bun"
    return
  fi

  if [[ "$detail" == *"Whisper installation finished without producing"* ]]; then
    echo "Whisper install failed. Rerun with: sudo labstrap extras whisper"
    return
  fi

  if [[ "$detail" == *"rbw installation finished without producing"* ]]; then
    echo "rbw install failed. Run: sudo labstrap extras homebrew && sudo labstrap extras rbw"
    return
  fi

  if [[ "$detail" == *"llama.cpp installation finished without producing"* ]]; then
    echo "llama.cpp install failed. Run: sudo labstrap extras homebrew && sudo labstrap extras llamacpp"
    return
  fi

  if [[ "$detail" == *"Herdr installation finished without producing"* ]]; then
    echo "Herdr install failed. Run: sudo labstrap extras herdr"
    return
  fi

  if [[ "$task" == *"Install nvm"* && "$detail" == *"Host key verification failed"* ]]; then
    echo "nvm git checkout failed due submodule host-key verification. Run: sudo rm -rf \"$(getent passwd $(config_value user) | cut -d: -f6)/.nvm\" ; then rerun: sudo labstrap extras node"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Ensure SSH is listening on configured port"* ]]; then
    echo "SSH did not come up on the configured port. Check /etc/ssh/sshd_config and run: sudo sshd -t"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Ensure ssh service is active"* ]]; then
    echo "SSH service is not active. Check: sudo systemctl status ssh ; if absent, check: sudo systemctl status sshd"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Validate SSH daemon configuration"* ]]; then
    echo "Invalid sshd config. Run: sudo /usr/sbin/sshd -t -f /etc/ssh/sshd_config ; fix errors ; rerun: sudo labstrap harden"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Fail if SSH daemon configuration is invalid"* ]]; then
    echo "Fix /etc/ssh/sshd_config syntax then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$detail" == *"Missing privilege separation directory"* ]]; then
    echo "Create runtime dir and retry: sudo mkdir -p /run/sshd && sudo chmod 755 /run/sshd ; then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Ensure OpenSSH server is installed"* ]]; then
    echo "OpenSSH server install failed. Run: sudo apt-get update && sudo apt-get install -y openssh-server ; then rerun: sudo labstrap harden"
    return
  fi

  if [[ "$phase" == "harden" && "$task" == *"Ensure tailscale0 firewall allowance exists"* ]]; then
    echo "UFW policy is missing tailscale0 allowance. Run: sudo ufw status verbose"
    return
  fi

  if [[ "$phase" == "preflight" ]]; then
    echo "Fix the preflight issue and rerun the same command."
    return
  fi

  echo "See log file for details: $LABSTRAP_LOG_FILE"
}

print_preflight_failure_summary() {
  local phase="$1"
  local line
  local msg

  if ! command -v python3 >/dev/null 2>&1; then
    echo "ERROR: Preflight failed for phase '$phase'. See log: $LABSTRAP_LOG_FILE" >&2
    return
  fi

  line="$(python3 - "$LABSTRAP_LOG_FILE" "$phase" <<'PY'
import json
import sys

path = sys.argv[1]
phase = sys.argv[2]
last = None
with open(path, "r", encoding="utf-8") as fp:
    for raw in fp:
        raw = raw.strip()
        if not raw:
            continue
        try:
            event = json.loads(raw)
        except json.JSONDecodeError:
            continue
        if event.get("event") == "preflight.check_failed" and event.get("phase") == phase:
            last = event

if last:
    print(last.get("message", "Preflight check failed"))
PY
)"

  msg="$(truncate_text "$line" 300)"
  if [[ -n "$msg" ]]; then
    echo "ERROR: Preflight failed for phase '$phase': $msg" >&2
    echo "Next: $(suggest_failure_hint "preflight" "" "$msg")" >&2
    echo "Log: $LABSTRAP_LOG_FILE" >&2
    return
  fi

  echo "ERROR: Preflight failed for phase '$phase'. See log: $LABSTRAP_LOG_FILE" >&2
}

print_ansible_failure_summary() {
  local phase="$1"
  local summary
  local task=""
  local status=""
  local detail=""
  local hint=""

  if ! command -v python3 >/dev/null 2>&1; then
    echo "ERROR: Phase '$phase' failed. See log: $LABSTRAP_LOG_FILE" >&2
    return
  fi

  summary="$(python3 - "$LABSTRAP_LOG_FILE" "$phase" <<'PY'
import json
import sys

path = sys.argv[1]
phase = sys.argv[2]
failure = None

with open(path, "r", encoding="utf-8") as fp:
    for raw in fp:
        raw = raw.strip()
        if not raw:
            continue
        try:
            event = json.loads(raw)
        except json.JSONDecodeError:
            continue
        if event.get("event") == "ansible.task" and event.get("phase") == phase and event.get("status") in {"failed", "unreachable"}:
            failure = event

if not failure:
    sys.exit(1)

task = failure.get("task", "")
status = failure.get("status", "")
detail = failure.get("msg") or failure.get("stderr") or failure.get("stdout") or ""
detail = " ".join(detail.split())
print(task)
print(status)
print(detail)
PY
)" || true

  if [[ -n "$summary" ]]; then
    task="$(printf '%s\n' "$summary" | sed -n '1p')"
    status="$(printf '%s\n' "$summary" | sed -n '2p')"
    detail="$(printf '%s\n' "$summary" | sed -n '3p')"
  fi

  task="$(truncate_text "$task" 180)"
  detail="$(truncate_text "$detail" 350)"
  hint="$(suggest_failure_hint "$phase" "$task" "$detail")"

  if [[ -n "$task" ]]; then
    echo "ERROR: Phase '$phase' failed at task: $task" >&2
  else
    echo "ERROR: Phase '$phase' failed." >&2
  fi

  if [[ -n "$status" ]]; then
    echo "Status: $status" >&2
  fi

  if [[ -n "$detail" ]]; then
    echo "Reason: $detail" >&2
  fi

  if [[ -n "$hint" ]]; then
    echo "Next: $hint" >&2
  fi
  echo "Log: $LABSTRAP_LOG_FILE" >&2
}

init_logging() {
  local command_name="$1"
  local configured_dir="${LABSTRAP_LOG_DIR:-/var/log/labstrap}"
  local log_dir="$configured_dir"
  local timestamp

  if ! mkdir -p "$log_dir" >/dev/null 2>&1; then
    log_dir="/tmp/labstrap"
    mkdir -p "$log_dir"
  fi

  timestamp="$(date -u +"%Y%m%dT%H%M%SZ")"
  LABSTRAP_LOG_FILE="$log_dir/${timestamp}-${command_name:-unknown}-$$.jsonl"
  : > "$LABSTRAP_LOG_FILE"
  export LABSTRAP_LOG_FILE

  log_event "INFO" "log.start" "Structured logging initialized" "log_file" "$LABSTRAP_LOG_FILE"
}

print_usage() {
  cat <<USAGE
Usage:
  labstrap init
  labstrap harden
  labstrap extras [component|all|--interactive|select]
  labstrap allow-key <path_to_pubkey>
  labstrap doctor [--fix]
  labstrap status
USAGE
}

banner() {
  echo
  echo "== $1 =="
}

require_root() {
  if [[ "$EUID" -ne 0 ]]; then
    log_event "ERROR" "auth.not_root" "Command requires sudo/root"
    echo "ERROR: This command must be run with sudo/root." >&2
    exit 1
  fi
}

require_command() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 || {
    log_event "ERROR" "dependency.missing" "Required command not found" "dependency" "$cmd"
    echo "ERROR: Missing required command: $cmd" >&2
    exit 1
  }
}

config_value() {
  local key="$1"
  local value
  value="$(awk -v key="$key" '$1 == key":" {print $2; exit}' "$CONFIG_PATH")"

  if [[ "$key" == "user" && ( -z "$value" || "$value" == "auto" ) ]]; then
    detect_target_user
    return
  fi

  printf '%s\n' "$value"
}

detect_target_user() {
  local candidate

  if [[ -n "${LABSTRAP_USER:-}" && "${LABSTRAP_USER:-}" != "root" ]]; then
    printf '%s\n' "$LABSTRAP_USER"
    return
  fi

  if [[ -n "${SUDO_USER:-}" && "${SUDO_USER:-}" != "root" ]]; then
    printf '%s\n' "$SUDO_USER"
    return
  fi

  candidate="$(logname 2>/dev/null || true)"
  if [[ -n "$candidate" && "$candidate" != "root" ]]; then
    printf '%s\n' "$candidate"
    return
  fi

  candidate="$(awk -F: '$3 >= 1000 && $3 < 65534 && $1 != "nobody" {print $1; exit}' /etc/passwd)"
  if [[ -n "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return
  fi

  return 1
}

target_user_shell() {
  local user_name="$1"
  local shell_path

  shell_path="$(getent passwd "$user_name" 2>/dev/null | cut -d: -f7)"
  if [[ -n "$shell_path" && -x "$shell_path" ]]; then
    printf '%s\n' "$shell_path"
    return
  fi

  printf '%s\n' /bin/bash
}

user_shell_command_available() {
  local user_name="$1"
  local user_home="$2"
  local shell_path="$3"
  local command_name="$4"

  if [[ "$EUID" -eq 0 ]]; then
    sudo -u "$user_name" \
      env HOME="$user_home" USER="$user_name" LOGNAME="$user_name" SHELL="$shell_path" \
      "$shell_path" -ic "command -v $command_name >/dev/null 2>&1"
    return
  fi

  HOME="$user_home" USER="$user_name" LOGNAME="$user_name" SHELL="$shell_path" \
    "$shell_path" -ic "command -v $command_name >/dev/null 2>&1"
}

config_nested_value() {
  local section="$1"
  local key="$2"
  awk -v section="$section" -v key="$key" '
    $0 ~ "^" section ":[[:space:]]*$" {in_section=1; next}
    in_section && $0 ~ "^[^[:space:]]" {in_section=0}
    in_section && $1 == key":" {print $2; exit}
  ' "$CONFIG_PATH"
}

is_valid_extra_component() {
  local component="$1"
  local candidate

  [[ "$component" == "all" ]] && return 0

  for candidate in "${EXTRAS_COMPONENTS[@]}"; do
    [[ "$candidate" == "$component" ]] && return 0
  done

  return 1
}

csv_has_component() {
  local csv="${1:-}"
  local target="$2"
  local item

  [[ -n "$csv" ]] || return 1
  IFS=',' read -r -a __labstrap_csv_items <<< "$csv"
  for item in "${__labstrap_csv_items[@]}"; do
    [[ "$item" == "$target" ]] && return 0
  done

  return 1
}

normalize_extras_csv() {
  local csv="${1:-}"
  local component
  local selected=()

  for component in "${EXTRAS_COMPONENTS[@]}"; do
    if csv_has_component "$csv" "$component"; then
      selected+=("$component")
    fi
  done

  local IFS=','
  printf '%s\n' "${selected[*]}"
}

toggle_component_in_csv() {
  local csv="${1:-}"
  local target="$2"
  local component
  local selected=()

  for component in "${EXTRAS_COMPONENTS[@]}"; do
    if [[ "$component" == "$target" ]]; then
      if ! csv_has_component "$csv" "$component"; then
        selected+=("$component")
      fi
      continue
    fi

    if csv_has_component "$csv" "$component"; then
      selected+=("$component")
    fi
  done

  local IFS=','
  printf '%s\n' "${selected[*]}"
}

current_extras_selection_csv() {
  local component
  local selected=()

  for component in "${EXTRAS_COMPONENTS[@]}"; do
    if [[ "$(config_nested_value extras "$component")" == "true" ]]; then
      selected+=("$component")
    fi
  done

  local IFS=','
  printf '%s\n' "${selected[*]}"
}

select_extras_with_whiptail() {
  local initial_csv="$1"
  local component
  local state
  local output
  local args=(
    --title "labstrap extras"
    --checklist
    "Select extras to keep enabled and/or run now."
    24
    78
    16
  )

  for component in "${EXTRAS_COMPONENTS[@]}"; do
    state="OFF"
    if csv_has_component "$initial_csv" "$component"; then
      state="ON"
    fi
    args+=("$component" "$component" "$state")
  done

  output="$(whiptail --separate-output "${args[@]}" 3>&1 1>&2 2>&3)" || return 1
  if [[ -z "$output" ]]; then
    printf '\n'
    return 0
  fi

  printf '%s\n' "$output" | paste -sd, -
}

select_extras_with_prompt() {
  local current_csv="$1"
  local input
  local token
  local index
  local component

  while true; do
    echo
    echo "Select extras to keep enabled and/or run now."
    for index in "${!EXTRAS_COMPONENTS[@]}"; do
      component="${EXTRAS_COMPONENTS[$index]}"
      if csv_has_component "$current_csv" "$component"; then
        printf '%2d. [x] %s\n' "$((index + 1))" "$component"
      else
        printf '%2d. [ ] %s\n' "$((index + 1))" "$component"
      fi
    done

    read -r -p "Numbers to toggle (space or comma separated). Press Enter when finished: " input || return 1
    [[ -z "$input" ]] && break
    input="${input//,/ }"

    for token in $input; do
      if [[ ! "$token" =~ ^[0-9]+$ ]]; then
        echo "Ignoring invalid selection: $token" >&2
        continue
      fi

      if (( token < 1 || token > ${#EXTRAS_COMPONENTS[@]} )); then
        echo "Ignoring out-of-range selection: $token" >&2
        continue
      fi

      component="${EXTRAS_COMPONENTS[$((token - 1))]}"
      current_csv="$(toggle_component_in_csv "$current_csv" "$component")"
    done
  done

  printf '%s\n' "$current_csv"
}

select_extras_interactively() {
  local initial_csv="$1"

  if command -v whiptail >/dev/null 2>&1; then
    select_extras_with_whiptail "$initial_csv"
    return
  fi

  select_extras_with_prompt "$initial_csv"
}

choose_extras_action() {
  local choice

  if command -v whiptail >/dev/null 2>&1; then
    choice="$(whiptail \
      --title "labstrap extras" \
      --menu "Choose what to do with the selected extras." \
      18 78 4 \
      run "Run selected extras now" \
      save "Save selected extras to config" \
      save_run "Save selected extras, then run them" \
      cancel "Exit without changes" \
      3>&1 1>&2 2>&3)" || return 1
    printf '%s\n' "$choice"
    return
  fi

  while true; do
    echo
    echo "Choose what to do next:"
    echo "  1. Run selected extras now"
    echo "  2. Save selected extras to config"
    echo "  3. Save selected extras, then run them"
    echo "  4. Cancel"
    read -r -p "Action [1-4]: " choice || return 1

    case "$choice" in
      1) printf 'run\n'; return ;;
      2) printf 'save\n'; return ;;
      3) printf 'save_run\n'; return ;;
      4) printf 'cancel\n'; return ;;
    esac

    echo "Invalid action: $choice" >&2
  done
}

save_extras_selection() {
  local selected_csv="$1"
  local components_csv
  local tmp_file

  components_csv="$(normalize_extras_csv "$(IFS=,; printf '%s' "${EXTRAS_COMPONENTS[*]}")")"
  tmp_file="$(mktemp /tmp/labstrap-config.XXXXXX)"

  awk \
    -v selected_csv="$selected_csv" \
    -v components_csv="$components_csv" '
      BEGIN {
        selected_count = split(selected_csv, selected, ",")
        for (i = 1; i <= selected_count; i++) {
          if (selected[i] != "") {
            selected_map[selected[i]] = 1
          }
        }

        component_count = split(components_csv, components, ",")
        for (i = 1; i <= component_count; i++) {
          if (components[i] != "") {
            component_map[components[i]] = 1
          }
        }
      }

      /^extras:[[:space:]]*$/ {
        print
        in_extras = 1
        next
      }

      in_extras && /^[^[:space:]]/ {
        in_extras = 0
      }

      in_extras {
        line = $0
        sub(/^[[:space:]]+/, "", line)
        split(line, parts, ":")
        key = parts[1]

        if (key in component_map) {
          printf "  %s: %s\n", key, ((key in selected_map) ? "true" : "false")
          next
        }
      }

      {
        print
      }
    ' "$CONFIG_PATH" > "$tmp_file"

  chmod 0644 "$tmp_file"
  mv "$tmp_file" "$CONFIG_PATH"
}

run_extras_interactive() {
  local initial_csv
  local selected_csv
  local action

  if [[ ! -t 0 || ! -t 1 ]]; then
    log_event "ERROR" "extras.interactive.no_tty" "Interactive extras mode requires a TTY"
    echo "ERROR: Interactive extras mode requires a TTY." >&2
    return 1
  fi

  initial_csv="$(current_extras_selection_csv)"
  selected_csv="$(select_extras_interactively "$initial_csv")" || {
    log_event "INFO" "extras.interactive.cancelled" "Interactive extras selection cancelled"
    echo "extras: cancelled."
    return 0
  }
  selected_csv="$(normalize_extras_csv "$selected_csv")"

  action="$(choose_extras_action)" || {
    log_event "INFO" "extras.interactive.cancelled" "Interactive extras action cancelled"
    echo "extras: cancelled."
    return 0
  }

  case "$action" in
    run)
      banner "Phase 3: extras (selected)"
      run_preflight extras
      run_ansible_phase extras all "$selected_csv"
      ;;

    save)
      save_extras_selection "$selected_csv"
      log_event "INFO" "extras.selection.saved" "Saved interactive extras selection" "selected" "$selected_csv"
      echo "extras: saved selection to $CONFIG_PATH"
      ;;

    save_run)
      save_extras_selection "$selected_csv"
      log_event "INFO" "extras.selection.saved" "Saved interactive extras selection" "selected" "$selected_csv"
      banner "Phase 3: extras (selected)"
      run_preflight extras
      run_ansible_phase extras all "$selected_csv"
      ;;

    cancel)
      log_event "INFO" "extras.interactive.cancelled" "Interactive extras action cancelled"
      echo "extras: cancelled."
      ;;

    *)
      echo "ERROR: Unknown extras action '$action'." >&2
      return 1
      ;;
  esac
}

run_preflight() {
  local phase="$1"
  log_event "INFO" "preflight.start" "Running preflight checks" "phase" "$phase"
  if LABSTRAP_CONFIG="$CONFIG_PATH" LABSTRAP_LOG_FILE="$LABSTRAP_LOG_FILE" "$PRECHECK_SCRIPT" "$phase"; then
    log_event "INFO" "preflight.success" "Preflight checks passed" "phase" "$phase"
    return 0
  fi

  log_event "ERROR" "preflight.failed" "Preflight checks failed" "phase" "$phase"
  print_preflight_failure_summary "$phase"
  return 1
}

run_ansible_phase() {
  local action="$1"
  shift || true

  require_command ansible-playbook
  log_event "INFO" "ansible.start" "Starting ansible phase" "phase" "$action"

  local args=(
    -i "$ANSIBLE_DIR/inventory.ini"
    "$ANSIBLE_DIR/playbook.yml"
    -e "labstrap_action=$action"
    -e "@$CONFIG_PATH"
    -e "user=$(config_value user)"
  )

  if [[ "$action" == "extras" ]]; then
    local component="${1:-all}"
    args+=( -e "extras_component=$component" )
    if [[ "$#" -ge 2 ]]; then
      local selected_csv="$2"
      args+=( -e "extras_selection_override=true" )
      args+=( -e "extras_selected_csv=$selected_csv" )
    fi
  fi

  if ANSIBLE_CALLBACK_PLUGINS="$ANSIBLE_DIR/callback_plugins${ANSIBLE_CALLBACK_PLUGINS:+:$ANSIBLE_CALLBACK_PLUGINS}" \
     ANSIBLE_STDOUT_CALLBACK=labstrap_jsonl \
     ANSIBLE_LOAD_CALLBACK_PLUGINS=1 \
     LABSTRAP_LOG_FILE="$LABSTRAP_LOG_FILE" \
     LABSTRAP_LOG_COMMAND="$LOG_COMMAND" \
     LABSTRAP_PHASE="$action" \
     ansible-playbook "${args[@]}"; then
    log_event "INFO" "ansible.success" "Ansible phase completed" "phase" "$action"
    return 0
  fi

  log_event "ERROR" "ansible.failed" "Ansible phase failed" "phase" "$action"
  print_ansible_failure_summary "$action"
  return 1
}

run_allow_key() {
  local key_file="$1"
  local user_name
  local home_dir
  local key_line

  log_event "INFO" "allow_key.start" "Processing SSH public key" "key_path" "$key_file"

  [[ -f "$key_file" ]] || {
    log_event "ERROR" "allow_key.invalid_path" "Public key file not found" "key_path" "$key_file"
    echo "ERROR: Public key file not found: $key_file" >&2
    exit 1
  }

  key_line="$(awk 'NF {print; exit}' "$key_file")"
  [[ -n "$key_line" ]] || {
    log_event "ERROR" "allow_key.empty_key" "Public key file is empty" "key_path" "$key_file"
    echo "ERROR: Public key file is empty: $key_file" >&2
    exit 1
  }

  case "$key_line" in
    ssh-*|ecdsa-*|sk-*) ;;
    *)
      log_event "ERROR" "allow_key.invalid_format" "Public key format appears invalid" "key_path" "$key_file"
      echo "ERROR: File does not appear to contain a valid SSH public key." >&2
      exit 1
      ;;
  esac

  user_name="$(config_value user)"
  [[ -n "$user_name" ]] || {
    log_event "ERROR" "allow_key.config_missing_user" "Unable to read user from config"
    echo "ERROR: Unable to read user from config." >&2
    exit 1
  }

  home_dir="$(getent passwd "$user_name" | cut -d: -f6)"
  [[ -n "$home_dir" && -d "$home_dir" ]] || {
    log_event "ERROR" "allow_key.user_home_missing" "Target user home directory missing" "user" "$user_name"
    echo "ERROR: Target user home directory not found for user '$user_name'." >&2
    exit 1
  }

  install -d -m 0700 -o "$user_name" -g "$user_name" "$home_dir/.ssh"
  touch "$home_dir/.ssh/authorized_keys"
  chown "$user_name:$user_name" "$home_dir/.ssh/authorized_keys"
  chmod 0600 "$home_dir/.ssh/authorized_keys"

  if grep -qxF "$key_line" "$home_dir/.ssh/authorized_keys"; then
    log_event "INFO" "allow_key.noop" "SSH key already present" "user" "$user_name"
    echo "allow-key: key already present for user '$user_name'."
    return
  fi

  printf '%s\n' "$key_line" >> "$home_dir/.ssh/authorized_keys"
  chown "$user_name:$user_name" "$home_dir/.ssh/authorized_keys"
  chmod 0600 "$home_dir/.ssh/authorized_keys"
  log_event "INFO" "allow_key.added" "SSH key added" "user" "$user_name"
  echo "allow-key: key added for user '$user_name'."
}

status_check() {
  local label="$1"
  local cmd="$2"

  if bash -c "$cmd" >/dev/null 2>&1; then
    log_event "INFO" "status.check" "Status check passed" "check" "$label" "result" "PASS"
    echo "[PASS] $label"
    return 0
  fi

  log_event "ERROR" "status.check" "Status check failed" "check" "$label" "result" "FAIL"
  echo "[FAIL] $label"
  return 1
}

status_check_user_command() {
