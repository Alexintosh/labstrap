  fi

  if [[ "$extras_rbw" == "true" ]]; then
    status_check "Extra: rbw installed" "[[ -x $user_home_q/.linuxbrew/bin/rbw || -x /home/linuxbrew/.linuxbrew/bin/rbw || -x $user_home_q/.local/bin/rbw ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_llamacpp" == "true" ]]; then
    status_check "Extra: llamacpp installed" "[[ -x $user_home_q/.linuxbrew/bin/llama-cli || -x /home/linuxbrew/.linuxbrew/bin/llama-cli || -x $user_home_q/.local/bin/llama-cli ]]" || failures=$((failures + 1))
  fi

  if [[ "$extras_herdr" == "true" ]]; then
    status_check_user_command "Extra: herdr installed" "$user_name" "$user_home" "$user_shell" herdr || failures=$((failures + 1))
  fi

  echo
  if [[ "$failures" -eq 0 ]]; then
    echo "status: OK"
    return 0
  fi

  echo "status: FAIL ($failures checks failed)"
  return 1
}

main() {
  local command="${1:-}"
  LOG_COMMAND="$command"
  init_logging "$command"
  log_event "INFO" "command.start" "Command execution started" "cmd_name" "${command:-<none>}"

  [[ -f "$CONFIG_PATH" ]] || {
    log_event "ERROR" "config.missing" "Configuration file not found" "config_path" "$CONFIG_PATH"
    echo "ERROR: Missing configuration file: $CONFIG_PATH" >&2
    exit 1
  }

  case "$command" in
    init)
      require_root
      banner "Phase 1: init"
      run_preflight init
      run_ansible_phase init
      ;;

    harden)
      require_root
      banner "Phase 2: harden"
      run_preflight harden
      run_ansible_phase harden
      ;;

    extras)
      require_root
      local component="${2:-}"
      if [[ -z "$component" ]]; then
        if [[ -t 0 && -t 1 ]]; then
          run_extras_interactive
        else
          banner "Phase 3: extras (all)"
          run_preflight extras
          run_ansible_phase extras all
        fi
      else
        case "$component" in
          --interactive|select)
            run_extras_interactive
            ;;
          *)
            if ! is_valid_extra_component "$component"; then
              echo "ERROR: Invalid extras component '$component'." >&2
              print_usage
              exit 1
            fi

            banner "Phase 3: extras ($component)"
            run_preflight extras
            run_ansible_phase extras "$component"
            ;;
        esac
      fi
      ;;

    allow-key)
      require_root
      local key_path="${2:-}"
      [[ -n "$key_path" ]] || {
        echo "ERROR: Missing key path." >&2
        print_usage
        exit 1
      }

      banner "allow-key"
      run_preflight allow-key
      run_allow_key "$key_path"
      ;;

    doctor)
      require_root
      local doctor_arg="${2:-}"
      local fix_mode="0"
      case "$doctor_arg" in
        "")
          ;;
        --fix)
          fix_mode="1"
          ;;
        *)
          echo "ERROR: Invalid doctor option '$doctor_arg'." >&2
          echo "Usage: labstrap doctor [--fix]" >&2
          exit 1
          ;;
      esac
      run_doctor "$fix_mode"
      ;;

    status)
      run_status
      ;;

    -h|--help|help)
      log_event "INFO" "command.help" "Displaying help output"
      print_usage
      ;;

    "")
      log_event "ERROR" "command.empty" "No command supplied"
      print_usage
      exit 1
      ;;

    *)
      log_event "ERROR" "command.unknown" "Unknown command" "cmd_name" "$command"
      echo "ERROR: Unknown command '$command'." >&2
      print_usage
      exit 1
      ;;
  esac

  log_event "INFO" "command.success" "Command execution completed" "cmd_name" "$command"
}

main "$@"
